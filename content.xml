VSVX</odeBlockId><blockName>Ejercicios tipo 1</blockName><iconName>objectives</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260426192748NDHBYD</odePageId><odeBlockId>20260426192748YQVSVX</odeBlockId><odeIdeviceId>2026042619353936286X</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;h1&gt;&lt;strong&gt;Ejercicio 1&lt;/strong&gt;&lt;/h1&gt;
&lt;p&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;📊 🧠&lt;strong&gt; Ejercicio: Cálculo del PIB por las 3 vías&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;En una economía se dispone de la siguiente información:&lt;/p&gt;
&lt;p&gt;&amp;nbsp;&lt;br&gt;&lt;strong&gt;🔹 1. VÍA DE LA PRODUCCIÓN (valor añadido)&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;&lt;img src="{{context_path}}/2026042619353936286X/mceclip0.png" width="583" height="186"&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;👉 PIB = suma de valores añadidos&lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;p&gt;Cálculo:&lt;/p&gt;
&lt;p&gt;Panadería: 1.000 − 400 = 600&lt;br&gt;Textil: 2.000 − 1.200 = 800&lt;br&gt;Librería: 1.500 − 500 = 1.000&lt;br&gt;👉 PIB = 600 + 800 + 1.000 = 2.400 €&lt;/p&gt;
&lt;p&gt;&amp;nbsp;&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;🔹 2. VÍA DEL GASTO&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Datos:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Consumo (C): 1.500 €&lt;/li&gt;
&lt;li&gt;Inversión (I): 500 €&lt;/li&gt;
&lt;li&gt;Gasto público (G): 600 €&lt;/li&gt;
&lt;li&gt;Exportaciones (X): 300 €&lt;/li&gt;
&lt;li&gt;Importaciones (M): 500 €&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;Fórmula:&lt;/p&gt;
&lt;p&gt;&amp;nbsp; &lt;img src="{{context_path}}/2026042619353936286X/mceclip1.png"&gt;&lt;/p&gt;
&lt;p&gt;Cálculo:&lt;/p&gt;
&lt;p&gt;PIB = 1.500 + 500 + 600 + (300 − 500)&lt;br&gt;PIB = 1.500 + 500 + 600 − 200&lt;br&gt;PIB = 2.400 €&lt;br&gt;&amp;nbsp;&lt;br&gt;&amp;nbsp;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;🔹 3. VÍA DE LA RENTA&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Datos:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Salarios: 1.500 €&lt;/li&gt;
&lt;li&gt;Beneficios empresariales: 700 €&lt;/li&gt;
&lt;li&gt;Impuestos: 300 €&lt;/li&gt;
&lt;li&gt;Subvenciones: 100 €&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;Fórmula:&lt;/p&gt;
&lt;p&gt;&amp;nbsp;&lt;img src="{{context_path}}/2026042619353936286X/mceclip2.png"&gt;&lt;/p&gt;
&lt;p&gt;Cálculo:&lt;/p&gt;
&lt;p&gt;PIB = 1.500 + 700 + (300 − 100)&lt;br&gt;PIB = 1.500 + 700 + 200&lt;br&gt;PIB = 2.400 €&lt;br&gt;&amp;nbsp;&lt;br&gt;&lt;strong&gt;✅ CONCLUSIÓN&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;👉 PIB por producción = 2.400 €&lt;br&gt;👉 PIB por gasto = 2.400 €&lt;br&gt;👉 PIB por renta = 2.400 €&lt;/p&gt;
&lt;p&gt;💡 Las 3 vías dan el mismo resultado, como debe ocurrir siempre.&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"2026042619353936286X","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;h1&gt;&lt;strong&gt;Ejercicio 1&lt;/strong&gt;&lt;/h1&gt;\n&lt;p&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;📊 🧠&lt;strong&gt; Ejercicio: Cálculo del PIB por las 3 vías&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;En una economía se dispone de la siguiente información:&lt;/p&gt;\n&lt;p&gt; &lt;br /&gt;&lt;strong&gt;🔹 1. VÍA DE LA PRODUCCIÓN (valor añadido)&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;&lt;img src=\"{{context_path}}/2026042619353936286X/mceclip0.png\" width=\"583\" height=\"186\" /&gt;&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;👉 PIB = suma de valores añadidos&lt;/p&gt;\n&lt;p&gt;&lt;/p&gt;\n&lt;p&gt;Cálculo:&lt;/p&gt;\n&lt;p&gt;Panadería: 1.000 − 400 = 600&lt;br /&gt;Textil: 2.000 − 1.200 = 800&lt;br /&gt;Librería: 1.500 − 500 = 1.000&lt;br /&gt;👉 PIB = 600 + 800 + 1.000 = 2.400 €&lt;/p&gt;\n&lt;p&gt; &lt;br /&gt;  &lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;🔹 2. VÍA DEL GASTO&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;Datos:&lt;/p&gt;\n&lt;ul&gt;\n&lt;li&gt;Consumo (C): 1.500 €&lt;/li&gt;\n&lt;li&gt;Inversión (I): 500 €&lt;/li&gt;\n&lt;li&gt;Gasto público (G): 600 €&lt;/li&gt;\n&lt;li&gt;Exportaciones (X): 300 €&lt;/li&gt;\n&lt;li&gt;Importaciones (M): 500 €&lt;/li&gt;\n&lt;/ul&gt;\n&lt;p&gt;Fórmula:&lt;/p&gt;\n&lt;p&gt;  &lt;img src=\"{{context_path}}/2026042619353936286X/mceclip1.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;Cálculo:&lt;/p&gt;\n&lt;p&gt;PIB = 1.500 + 500 + 600 + (300 − 500)&lt;br /&gt;PIB = 1.500 + 500 + 600 − 200&lt;br /&gt;PIB = 2.400 €&lt;br /&gt; &lt;br /&gt; &lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;🔹 3. VÍA DE LA RENTA&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;Datos:&lt;/p&gt;\n&lt;ul&gt;\n&lt;li&gt;Salarios: 1.500 €&lt;/li&gt;\n&lt;li&gt;Bene